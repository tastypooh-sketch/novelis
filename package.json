{
  "name": "novelis-desktop",
  "version": "8.0.05",
  "description": "Novelis Desktop App",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/tastypooh-sketch/novelis"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npx esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac --universal",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:all": "npm run build && electron-builder -mwl",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": {
    "name": "Novelis",
    "email": "contact@novelis.app"
  },
  "license": "ISC",
  "dependencies": {
    "@google/genai": "*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "docx": "^8.5.0",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "immer": "^10.1.3",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.4",
    "use-debounce": "^10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.novelis.app",
    "productName": "Novelis",
    "icon": "public/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "tastypooh-sketch",
        "repo": "novelis"
      }
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "${productName}_Windows_Setup_${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "artifactName": "${productName}_macOS_${version}_${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Novelis <contact@novelis.app>",
      "icon": "public/icon.png",
      "category": "Office",
      "synopsis": "A minimalist novel writing app",
      "artifactName": "${productName}_Linux_Chromebook_${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Novelis",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "license": "EULA.txt"
    }
  }
}
